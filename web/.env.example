# ── Database — Neon (https://console.neon.tech) ──────────────────────────────
# Settings → Connection Details → "Pooled connection" / "Connection string"
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with:  npx auth secret  (or `openssl rand -base64 32`)
AUTH_SECRET=

# Production URL (used for OAuth callbacks). Set to your Vercel URL on deploy.
AUTH_URL=http://localhost:3000

# ── LINE Login (developers.line.biz → your LINE Login channel → Basic settings) ─
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Add this LINE Callback URL in your Channel → LINE Login tab:
#   http://localhost:3000/api/auth/callback/line   (dev)
#   https://<project>.vercel.app/api/auth/callback/line   (prod)
